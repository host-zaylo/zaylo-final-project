---
import texts from "../../texts.json";
---

<section id="content" class="w-full flex flex-col justify-center items-center">
  <div class="relative w-full flex justify-center items-center bg-[radial-gradient(ellipse_at_center,_#1A2327_0%,_#131819_45%,_#000000_100%)]">
    <div class="relative w-full aspect-[3/4] overflow-hidden sm:max-h-212">
      <img src="/photos/sobre/05.webp" alt="Zaylo" class="absolute inset-0 w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/60 flex flex-col items-center justify-center gap-6 p-4">
        <div class="flex flex-col justify-between items-center w-full h-full py-4">
          <div class="absolute bottom-0 left-0 right-0 h-64 bg-gradient-to-t from-black via-black/50 to-transparent z-10"></div>
          <div class="flex justify-end z-20 py-8 h-full items-center flex-col w-full gap-2">
            <p class="text-white text-xs md:text-xs font-body font-light tracking-base px-4 text-center animate-fade-up">
              {texts.about["text-06"]}
            </p>
            <p class="text-white text-xs md:text-xs font-body font-light tracking-base px-4 text-center animate-fade-up" style="animation-delay: 0.3s">
              {texts.about["text-07"]}
            </p>
            <p class="text-white text-xs md:text-xs font-body tracking-base px-4 text-center animate-fade-up" style="animation-delay: 0.4s">
              {texts.about["text-08"]}
            </p>
            <img src="/logos/favicon-zaylo.png" class="max-w-8" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up {
    animation: fadeUp 0.8s ease-out 0.2s both;
  }
</style>
