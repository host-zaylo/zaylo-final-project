---
import texts from "../../texts.json";
---

<section id="conteudo" class="w-full flex flex-col justify-center items-center">
  <div class="relative w-full flex justify-center items-center">
    <div class="relative w-full aspect-[3/4] overflow-hidden sm:max-h-212">
      <img src="/photos/zaylo-06.webp" alt="Banner" class="absolute inset-0 w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/40 flex flex-col items-center justify-center gap-6 p-4">
        <div class="flex flex-col justify-end items-center w-full h-full py-4 gap-4">
          <div class="flex flex-col w-full justify-center items-center">
            <h2 class="text-white text-md md:text-4xl font-body font-light uppercase tracking-widest px-4 animate-fade-up">
              {texts.home.zaylo}
            </h2>
            <h2 class="text-white text-4xl md:text-4xl font-heading font-medium tracking-tight px-4 animate-fade-up" style="animation-delay: 0.2s">
              {texts.home.arrivals}
            </h2>
          </div>
          <div class="flex justify-center items-center w-full">
            <a href="/produtos" class="text-white px-4 py-2 rounded-full font-body font-light uppercase tracking-wide text-md hover:-translate-y-1 transition duration-300 z-10 underline underline-offset-8 animate-fade-up" style="animation-delay: 0.4s">
              {texts.home.more}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(32px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up {
    animation: fadeUp 0.6s ease-out both;
  }
</style>
