---
import Layout from '../layouts/Layout.astro';
import ContentPageWrapper from '../components/UI/ContentPageWrapper'; // Ensure correct path
---

<Layout title="FAQs">
  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-element-bundle.min.js"></script>

  <section class="w-full flex flex-col gap-12 m-8 px-4 md:px-16 py-16 sm:py-16 text-white bg-[#232222]/80 justify-center items-start ml-8 mr-8">
    <div class="text-right">
        <h1 class="text-4xl font-bold mb-6 fill-over-stroke font-heading stroke-4 stroke-black">FAQs</h1>
    </div>

    <div class="w-full flex justify-center items-center">
      <ContentPageWrapper title="Frequently Asked Questions" client:load>
        <p><strong>Q: How do I track my order?</strong></p>
        <p>A: Once your order ships, you will receive a tracking number via email.</p>
        <p><strong>Q: Can I change my order after it's placed?</strong></p>
        <p>A: We process orders quickly. Please contact us immediately if you need to make changes.</p>
        <p><strong>Q: Do you offer international shipping?</strong></p>
        <p>A: Yes, we ship worldwide with tracking included.</p>
      </ContentPageWrapper>
    </div>
  </section>
</Layout>